{
	auto_https off
	debug
}

http://:{$PORT:8080} {
	log {
		output stdout
		format console
		level DEBUG
	}

	# Enable compression for static assets
	encode gzip zstd

	# WebSocket Proxy for Xray
	@ws path /ws /ws/*
	handle @ws {
		reverse_proxy 127.0.0.1:10086 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
			flush_interval -1
		}
	}

	# gRPC Proxy for Xray (using cleartext HTTP/2)
	@grpc path /grpc /grpc/*
	handle @grpc {
		reverse_proxy 127.0.0.1:10087 {
			header_up Host {host}
			header_up X-Forwarded-Proto {scheme}
			transport http {
				versions h2c 2
			}
			flush_interval -1
		}
	}

	# Configuration Endpoint for the Dashboard
	handle /health {
		respond "ok" 200
	}

	handle /config {
		header Content-Type "application/json"
		respond `{"uuid": "{$UUID:d342d11e-d424-4583-b36e-524ab1f0afa4}", "ws_path": "/ws", "grpc_service": "grpc"}` 200
	}

	# Serve the premium dashboard static files
	handle {
		root * /app/public
		file_server
	}
}
